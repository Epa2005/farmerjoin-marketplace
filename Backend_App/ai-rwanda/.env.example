# ===== AI Provider (choose ONE) =====
# Option 1: Lovable AI Gateway (recommended — Gemini + GPT, ready out of the box)
LOVABLE_API_KEY=your_lovable_api_key_here
AI_MODEL=google/gemini-2.5-flash

# Option 2: Local Ollama (offline / self-hosted)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava

# ===== Weather (OpenWeatherMap — free tier works) =====
WEATHER_API_KEY=your_openweathermap_api_key

# ===== Server =====
PORT=5005
# CORS — your React/Node frontend origin (use * for any during dev)
CORS_ORIGIN=*

# NOTE: NO authentication is required. All endpoints are open.
